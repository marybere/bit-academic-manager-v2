# ── PostgreSQL ──────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bit_academic_manager
DB_USER=postgres
DB_PASSWORD=your_password_here

# ── JWT ─────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# ── Server ──────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── CORS ────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
